# NinjaOne API credentials (required)
# Get these from NinjaOne Administration > Apps > API
NINJAONE_CLIENT_ID=your-client-id-here
NINJAONE_CLIENT_SECRET=your-client-secret-here

# NinjaOne region (optional, default: us)
# Valid: us, eu, oc, ca, us2, fed
NINJAONE_REGION=us

# Transport mode (optional, default: stdio)
# stdio = Claude Desktop / CLI local usage
# http  = hosted deployment (Docker, cloud, shared server)
MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# Authentication mode (only used when MCP_TRANSPORT=http)
# env     = credentials from environment variables (single-user)
# gateway = credentials from request headers (multi-user)
AUTH_MODE=env

# Logging (optional, default: info)
# Valid: debug, info, warn, error
LOG_LEVEL=info
